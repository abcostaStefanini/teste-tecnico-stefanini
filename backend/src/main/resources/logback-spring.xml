<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- Console com padrão legível para desenvolvimento local -->
    <appender name="CONSOLE_PLAIN" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Console em JSON estruturado (perfil docker / produção) -->
    <appender name="CONSOLE_JSON" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <includeMdcKeyName>traceId</includeMdcKeyName>
            <customFields>{"application":"task-manager"}</customFields>
        </encoder>
    </appender>

    <!-- Perfil docker: logs em JSON -->
    <springProfile name="docker">
        <root level="INFO">
            <appender-ref ref="CONSOLE_JSON"/>
        </root>
    </springProfile>

    <!-- Perfis local/default (qualquer perfil que não seja docker): logs legíveis -->
    <springProfile name="!docker">
        <root level="INFO">
            <appender-ref ref="CONSOLE_PLAIN"/>
        </root>
    </springProfile>

</configuration>
